# ============================================================
#  Virtual SDR Agent — Environment Configuration
#  Copy to .env for local dev, or paste into Railway Variables
# ============================================================

# ── Authentication ───────────────────────────────────────────
# Plain-text password for the login page (set one or the other)
APP_PASSWORD=changeme

# OR: SHA-256 hash of your password (more secure for cloud):
# Generate with: python -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"
# APP_PASSWORD_HASH=

# Random secret for session signing (generate once, never change)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Prius Signals ────────────────────────────────────────────
PRIUS_SIGNALS_BASE_URL=https://signals.priusintelli.com
PRIUS_SIGNALS_TOKEN=

# ── HubSpot ──────────────────────────────────────────────────
# Private App token (scopes: crm.objects.contacts.read)
HUBSPOT_TOKEN=

# ── Apollo.io ────────────────────────────────────────────────
APOLLO_API_KEY=

# ── Scheduler ────────────────────────────────────────────────
# Hour (UTC) for Thursday morning pipeline
# 7am CDT = 12 UTC | 7am CST = 13 UTC
SCHEDULE_HOUR_UTC=13
